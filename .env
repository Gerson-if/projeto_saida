# ============================================================
# .env.example — Copie para .env e preencha antes de executar
# ============================================================

# Chave secreta do Flask (obrigatória em produção — use uma string longa e aleatória)
SECRET_KEY=troque-esta-chave-por-uma-muito-longa-e-aleatoria

# Ambiente: development | production | testing
FLASK_ENV=production
FLASK_APP=run.py

# ── Banco de dados ───────────────────────────────────────────
# SQLite (desenvolvimento — não usar em produção)
# DATABASE_URL=sqlite:///instance/sistema_saida.db

# MySQL / MariaDB (recomendado para produção)
 DATABASE_URL=mysql+pymysql://root:admin@localhost:3307/saida

# PostgreSQL (alternativa)
# DATABASE_URL=postgresql+psycopg2://usuario:senha@localhost/sistema_saida

# ── Identidade visual (opcional — sobrescrito pelo painel admin) ──
# SISTEMA_NOME=Sistema de Controle de Saídas
# SISTEMA_SUBTITULO=Gestão de Saídas de Guarnição
# SISTEMA_ORGANIZACAO=Organização Militar

# ── Agendador de status automático ──────────────────────────
# Intervalo em minutos entre execuções do job de atualização
# SCHEDULER_STATUS_INTERVAL_MINUTES=10
