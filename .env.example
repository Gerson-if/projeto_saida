# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copie para .env e ajuste os valores
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente: development | production | testing
FLASK_ENV=development

# Chave secreta das sessões (obrigatória em produção — gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-esta-chave-em-producao

# Banco de dados
# Dev (SQLite, padrão — não precisa definir):
# DATABASE_URL=sqlite:///instance/sistema_saida.db
#
# Produção (MariaDB/MySQL):
# DATABASE_URL=mysql+pymysql://usuario:senha@localhost/nome_banco

# Identidade visual (opcional — pode ser configurado pelo admin no painel)
# SISTEMA_NOME=Sistema de Controle de Saídas
# SISTEMA_SUBTITULO=Gestão de Saídas de Guarnição
# SISTEMA_ORGANIZACAO=Organização Militar

# Intervalo do scheduler de atualização de status (minutos)
# SCHEDULER_STATUS_INTERVAL_MINUTES=10
